{
  "name": "@translation-master/i18n-migrate-cli",
  "type": "module",
  "version": "0.0.1",
  "description": "CLI for extracting and applying source-level i18n migrations",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy-collection/translation-master#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy-collection/translation-master.git"
  },
  "bugs": "https://github.com/hackycy-collection/translation-master/issues",
  "keywords": [
    "i18n",
    "translation",
    "cli"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./bin/tmigrate": {
      "import": "./dist/bin/tmigrate.mjs",
      "require": "./dist/bin/tmigrate.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "tmigrate": "./dist/bin/tmigrate.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@babel/parser": "catalog:cli",
    "@clack/prompts": "catalog:cli",
    "@translation-master/core": "workspace:*",
    "@translation-master/node": "workspace:*",
    "@vue/compiler-sfc": "catalog:cli",
    "commander": "catalog:cli",
    "picocolors": "catalog:cli",
    "tinyglobby": "catalog:cli",
    "yaml": "catalog:testing"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
